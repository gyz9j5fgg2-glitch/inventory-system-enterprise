# 环境变量模板 - HTTPS强制版
# 复制此文件为 .env 并填写实际值

# ============================================
# 安全密钥 (必填，生产环境必须设置)
# 生成长度>=32的随机字符串:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
# ============================================
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_MIN_32_CHARS

# ============================================
# 数据库配置 (必填)
# ============================================
DATABASE_URL=postgresql+asyncpg://inventory:YourStrongPassword@localhost:5432/inventory

# ============================================
# Redis配置
# ============================================
REDIS_URL=redis://:YourRedisPassword@localhost:6379/0
CELERY_BROKER_URL=redis://:YourRedisPassword@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:YourRedisPassword@localhost:6379/2

# ============================================
# LDAP配置 (可选，必须使用LDAPS)
# ============================================
LDAP_ENABLED=false
LDAP_SERVER=ldaps://ad.company.com:636
LDAP_BASE_DN=dc=company,dc=com
LDAP_USER_DN=cn=admin,dc=company,dc=com
LDAP_PASSWORD=YourLDAPPassword

# ============================================
# HTTPS配置
# ============================================
# 如果使用反向代理（如Nginx/负载均衡器），不需要配置以下两项
# 如果直接暴露API服务，需要配置SSL证书
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# ============================================
# 应用配置
# ============================================
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# CORS配置 - 必须使用HTTPS域名
# 示例: https://inventory.company.com
# ============================================
CORS_ORIGINS=https://inventory.company.com,https://admin.company.com
